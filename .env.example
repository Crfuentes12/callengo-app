# ============================================================
# Callengo — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # REQUIRED in production (e.g., https://app.callengo.com)
NODE_ENV=development

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Bland AI (Voice Calls) ---
BLAND_API_KEY=your-bland-api-key
BLAND_COST_PER_MINUTE=0.11   # Optional: override default cost per minute

# --- OpenAI (AI Analysis) ---
OPENAI_API_KEY=sk-...

# --- Upstash Redis (Rate Limiting & Concurrency) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# --- Internal Security ---
INTERNAL_API_SECRET=generate-a-random-secret-here    # Service-to-service auth
QUEUE_PROCESSING_SECRET=generate-a-random-secret-here  # Cron job auth
CRON_SECRET=generate-a-random-secret-here             # Vercel Cron auth
OAUTH_STATE_SECRET=generate-a-random-secret-here      # OAuth state HMAC signing

# --- reCAPTCHA ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# --- Seed Endpoint (dev/staging only) ---
# SEED_ENDPOINT_SECRET=your-seed-secret   # Only set this if you need the seed endpoint

# --- CRM Integrations (OAuth) ---
# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# SALESFORCE_LOGIN_URL=https://login.salesforce.com   # Use test.salesforce.com for sandbox

# Pipedrive
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# Zoho
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Microsoft Dynamics 365
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_TENANT_ID=

# Clio
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# --- Calendar Integrations ---
# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Outlook
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- Other Integrations ---
# Google Sheets
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# SimplyBook
# SIMPLYBOOK_API_KEY=
# SIMPLYBOOK_SECRET=
