# ============================================================
# Callengo — Environment Variables
# Copy this file to .env.local and fill in the values
# Last updated: 23 March 2026
# ============================================================

# ============================================================
# CORE INFRASTRUCTURE
# ============================================================

# --- Supabase (Database + Auth) ---
# Required: Get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-only. Bypasses RLS. NEVER expose to client.

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Production: https://app.callengo.com
NODE_ENV=development

# ============================================================
# PAYMENTS — Stripe
# ============================================================

# Required: Get from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...                       # Server-only. Use sk_live_... in production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...      # Public. Use pk_live_... in production.
STRIPE_WEBHOOK_SECRET=whsec_...                     # From Stripe CLI or Dashboard → Webhooks

# ============================================================
# VOICE / TELEPHONY — Bland AI
# ============================================================

# Required: Master API key from Bland AI dashboard
# Architecture: Single master key for ALL companies (no sub-accounts)
# Company isolation handled via company_id in Supabase
BLAND_API_KEY=your-bland-api-key
BLAND_WEBHOOK_SECRET=your-bland-webhook-secret      # HMAC-SHA256 webhook signature verification
BLAND_COST_PER_MINUTE=0.11                          # Optional: override default cost/min (used for P&L calculations)

# ============================================================
# AI ANALYSIS — OpenAI
# ============================================================

# Required: GPT-4o-mini for post-call intent analysis
# Used with temperature=0.1, JSON mode, for BANT scoring, data validation, appointment intent
OPENAI_API_KEY=sk-...
AI_ANALYSIS_MODE=sync                               # 'sync' (inline in webhook, up to 10s) or 'async' (via analysis_queue)

# ============================================================
# CONCURRENCY & RATE LIMITING — Upstash Redis
# ============================================================

# Required: Serverless Redis for call slot management, rate limiting, Bland plan caching
# Get from Upstash Console → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================================
# PRODUCT ANALYTICS
# ============================================================

# --- Google Analytics 4 ---
# Optional: 130+ custom events tracked client-side (gtag.js) and server-side (Measurement Protocol)
# Get from GA4 Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX          # Public. Format: G-XXXXXXXXXX
GA_API_SECRET=your-ga-api-secret                    # Server-only. For Measurement Protocol server events.

# --- PostHog ---
# Optional: Session replay, feature flags, group analytics (company-level), 20 event categories
# Get from PostHog → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXX       # Public. PostHog project key.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # Optional. Default: US cloud. Use https://eu.i.posthog.com for EU.

# ============================================================
# INTERNAL SECURITY & AUTH
# ============================================================

# Required: Generate random 32+ char secrets for each
TOKEN_ENCRYPTION_KEY=your-64-hex-char-key           # AES-256-GCM key for OAuth token encryption. Exactly 64 hex chars.
INTERNAL_API_SECRET=generate-a-random-secret-here   # Service-to-service API authentication
QUEUE_PROCESSING_SECRET=generate-a-random-secret    # Cron job / queue processor authentication
CRON_SECRET=generate-a-random-secret                # Vercel Cron job authentication
OAUTH_STATE_SECRET=generate-a-random-secret         # HMAC signing for OAuth state parameters

# --- reCAPTCHA v3 ---
# Optional: Bot protection on auth forms
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key        # Public. From Google reCAPTCHA admin.
RECAPTCHA_SECRET_KEY=your-secret-key                # Server-only.

# --- Seed Endpoint (dev/staging ONLY — never set in production) ---
# SEED_ENDPOINT_SECRET=your-seed-secret

# ============================================================
# CRM INTEGRATIONS (OAuth 2.0)
# ============================================================
# Each CRM requires client credentials from their developer portal.
# Plan gating: HubSpot/Pipedrive/Zoho/Clio → Business+, Salesforce/Dynamics → Teams+
# All tokens encrypted with AES-256-GCM before storage in DB.

# --- HubSpot (Business+) ---
HUBSPOT_APP_ID=                                     # From HubSpot Developer Portal
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_PRIVATE_APP_TOKEN=                          # Private app token for server-side API calls

# --- HubSpot Marketing (Contact Forms) ---
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=                      # HubSpot portal ID for embedded forms
NEXT_PUBLIC_HUBSPOT_CONTACT_FORM_ID=                # Contact form GUID

# --- Salesforce (Teams+) ---
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com   # Use https://test.salesforce.com for sandbox

# --- Pipedrive (Business+) ---
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# --- Zoho CRM (Business+) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# --- Microsoft Dynamics 365 (Teams+) ---
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_TENANT_ID=                                 # Azure AD tenant ID

# --- Clio (Business+ — Legal CRM) ---
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# --- SimplyBook.me (Free+ — API Key auth, not OAuth) ---
# Configured per-company in the integrations UI, not via env vars.
# SIMPLYBOOK_API_KEY=
# SIMPLYBOOK_SECRET=

# ============================================================
# CALENDAR INTEGRATIONS (OAuth 2.0)
# ============================================================

# --- Google Calendar + Google Sheets (Free+) ---
# Same credentials used for Google Calendar, Google Meet, and Google Sheets
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Outlook Calendar (Business+) ---
# Get from Azure Portal → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=                                # Azure AD tenant ID

# ============================================================
# VIDEO CONFERENCING
# ============================================================

# --- Zoom (Free+) ---
# Get from Zoom Marketplace → Develop → Build App
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ============================================================
# OTHER INTEGRATIONS
# ============================================================

# --- Slack (Starter+) ---
# Get from Slack API → Your Apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=                               # For verifying Slack webhook signatures

# --- Resend (Transactional Email) ---
# Used for team invitations, notifications
RESEND_API_KEY=re_...
